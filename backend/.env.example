APP_NAME=Amahoro Backend
APP_ENV=development
APP_DEBUG=true

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/amahoro

CORS_ORIGINS=http://localhost:3000
CORS_ORIGIN_REGEX=
SESSION_COOKIE_NAME=amahoro_session
SESSION_DURATION_HOURS=168
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

GEMINI_API_KEY=
CHATGROQ_API_KEY=
TAVILY_API_KEY=
TAVILY_TIMEOUT_SECONDS=15
TAVILY_MAX_RESULTS=4
PRIMARY_LLM_TIMEOUT_SECONDS=10
FALLBACK_LLM_TIMEOUT_SECONDS=15
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BASE_DELAY_SECONDS=0.5
LLM_RETRY_MAX_DELAY_SECONDS=6.0
