NEXT_PUBLIC_API_URL=http://localhost:8000

APP_NAME=Amahoro Backend
APP_ENV=development
APP_DEBUG=true



CORS_ORIGINS=http://localhost:3000
SESSION_COOKIE_NAME=amahoro_session
SESSION_DURATION_HOURS=168
SESSION_COOKIE_SECURE=false


PRIMARY_LLM_TIMEOUT_SECONDS=10
FALLBACK_LLM_TIMEOUT_SECONDS=15
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BASE_DELAY_SECONDS=0.5
LLM_RETRY_MAX_DELAY_SECONDS=6.0

# LangSmith Tracing (Optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="mentalhealthsolution"

# JWT_SECRET: Secret key for signing authentication tokens.
JWT_SECRET=imanairaturindaiminsiyosenomunziraucamo

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=your_gemini_api_key_here

CHATGROQ_API_KEY=your_groq_api_key_here

# DATABASE_URL: Supabase PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/database

# TAVILY_API_KEY: Required for web research agent
TAVILY_API_KEY=your_tavily_api_key_here



